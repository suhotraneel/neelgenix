{
  "name": "temp-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently \"vite\" \"node cms-server.js\"",
    "dev:host": "concurrently \"vite --host\" \"node cms-server.js\"",
    "cms": "node cms-server.js",
    "seo:generate": "node scripts/generate-seo-artifacts.mjs",
    "seo:validate": "node scripts/validate-seo.mjs",
    "build": "npm run seo:generate && npm run seo:validate && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
    "matter-js": "^0.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "express": "^5.2.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "multer": "^2.1.1",
    "vite": "^8.0.4"
  }
}
